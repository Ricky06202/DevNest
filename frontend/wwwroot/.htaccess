# .htaccess simplificado para estabilidad máxima (Sin Compresión)
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    RewriteRule ^index\.html$ - [L]
    
    # NO redirigir archivos que existen físicamente (CSS, JS, imágenes, etc.)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]
    
    # Excluir la carpeta /api del ruteo de Blazor
    RewriteCond %{REQUEST_URI} ^/api/
    RewriteRule ^ - [L]
    
    # Redirigir el resto al index para manejo de SPA
    RewriteRule ^(.*)$ index.html [L]
</IfModule>

@page "/login"
@inject AuthService AuthService
@inject NavigationManager NavigationManager

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-16">
    <MudCard Elevation="0" Class="pa-8 neon-card">
        <MudCardHeader Class="flex-column align-center pb-8">
            <CardHeaderContent>
                <div class="d-flex align-center justify-center mb-4">
                    <div style="background: rgba(59, 130, 246, 0.1); padding: 12px; border-radius: 12px; border: 1px solid rgba(59, 130, 246, 0.2);">
                        <MudIcon Icon="@Icons.Material.Rounded.Terminal" Color="Color.Primary" Style="font-size: 2.5rem;" />
                    </div>
                </div>
                <MudText Typo="Typo.h4" Align="Align.Center" Style="font-weight: 800; color: #f8fafc; letter-spacing: -1px;">
                    Bienvenido de Nuevo
                </MudText>
                <MudText Typo="Typo.body2" Align="Align.Center" Style="color: #64748b;" Class="mt-1">
                    Ingresa a tu entorno de desarrollo en DevNest
                </MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-6" Style="background: rgba(239, 68, 68, 0.05); border-color: rgba(239, 68, 68, 0.2); color: #fca5a5;">
                    @errorMessage
                </MudAlert>
            }
            
            <EditForm Model="loginModel" OnValidSubmit="HandleLogin">
                <DataAnnotationsValidator />
                
                <MudTextField @bind-Value="loginModel.Username" 
                               Label="Nombre de Usuario" 
                               Variant="Variant.Outlined" 
                               Adornment="Adornment.Start"
                               AdornmentIcon="@Icons.Material.Rounded.Person"
                               AdornmentColor="Color.Secondary"
                               Required="true"
                               Class="mb-6 login-input"/>
                               
                <MudTextField @bind-Value="loginModel.Password" 
                               Label="Contraseña" 
                               InputType="InputType.Password" 
                               Variant="Variant.Outlined" 
                               Adornment="Adornment.Start"
                               AdornmentIcon="@Icons.Material.Rounded.Lock"
                               AdornmentColor="Color.Secondary"
                               Required="true"
                               Class="mb-8 login-input"/>

                <MudButton ButtonType="ButtonType.Submit" 
                           Variant="Variant.Filled" 
                           Color="Color.Primary" 
                           Size="Size.Large" 
                           FullWidth="true" 
                           Disabled="@isLoading"
                           Class="mud-button-filled py-3"
                           Style="font-weight: 700; text-transform: none; font-size: 1.1rem; border-radius: 12px;">
                    @if (isLoading)
                    {
                        <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true"/>
                        <span class="ms-3">Iniciando Sesión...</span>
                    }
                    else
                    {
                        <span>Entrar a la Terminal</span>
                    }
                </MudButton>
            </EditForm>
        </MudCardContent>
        <MudCardActions Class="justify-center mt-4">
            <MudText Style="color: #64748b;">¿Nuevo aquí?</MudText>
            <MudLink Href="/register" Color="Color.Secondary" Underline="Underline.Hover" Class="ml-2" Style="font-weight: 600;">Regístrate</MudLink>
        </MudCardActions>
    </MudCard>
</MudContainer>

<style>
    .login-input :deep(.mud-input-outlined-border) {
        border-color: rgba(255, 255, 255, 0.08) !important;
    }
    .login-input :deep(.mud-input-label) {
        color: #94a3b8 !important;
    }
    .login-input :deep(input) {
        color: #f8fafc !important;
        font-family: 'Inter', sans-serif;
    }
</style>

@code {
    private LoginRequest loginModel = new();
    private bool isLoading = false;
    private string? errorMessage;

    private async Task HandleLogin()
    {
        isLoading = true;
        errorMessage = null;

        var success = await AuthService.LoginAsync(loginModel);

        if (success)
        {
            NavigationManager.NavigateTo("/");
        }
        else
        {
            errorMessage = "Usuario o contraseña incorrectos.";
        }

        isLoading = false;
    }
}

@page "/projects/{Id:int}"
@attribute [Authorize]
@inject HttpClient Http
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider
@using System.ComponentModel.DataAnnotations

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">
    <MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Color="Color.Default" OnClick="GoBack" Class="mb-4">Volver al Radar</MudButton>

    @if (isLoading)
    {
        <div class="d-flex justify-center mt-10">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        </div>
    }
    else if (project == null)
    {
        <MudAlert Severity="Severity.Error" Class="mt-5">El proyecto no existe o fue eliminado.</MudAlert>
    }
    else
    {
        <MudCard Elevation="5" Class="pa-6">
            <MudCardHeader>
                <CardHeaderContent>
                    <div class="d-flex justify-space-between align-start">
                        <div>
                            <MudText Typo="Typo.h3" Color="Color.Primary" Class="mb-2"><b>@project.title</b></MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                Creado por <b>@project.owner_username</b> el @project.created_at.ToString("dd MMMM yyyy")
                            </MudText>
                        </div>
                        <div>
                                @if (project.is_open)
                                {
                                    <MudChip T="string" Color="Color.Success" Size="Size.Large" Icon="@Icons.Material.Filled.LockOpen">Estado: Abierto</MudChip>
                                }
                                else
                                {
                                    <MudChip T="string" Color="Color.Error" Size="Size.Large" Icon="@Icons.Material.Filled.Lock">Estado: Cerrado</MudChip>
                                }

                                @if (isOwner)
                                {
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Class="ml-2" OnClick="NavigateToEdit" />
                                }
                            </div>
                    </div>
                </CardHeaderContent>
            </MudCardHeader>

            <MudCardContent Class="mt-0 pa-0">
                <MudTabs Elevation="0" Rounded="false" Class="mt-2">
                    <MudTabPanel Text="Detalles del Proyecto" Icon="@Icons.Material.Filled.Info">
                        <MudText Typo="Typo.h6" Class="mb-3"><b>Acerca de este proyecto</b></MudText>
                        
                        <MudPaper Elevation="0" Class="pa-4 mb-6" Style="background-color: var(--mud-palette-background-grey);">
                            <MudText Typo="Typo.body1" Style="white-space: pre-wrap; font-size: 1.1rem; line-height: 1.6;">@project.description</MudText>
                        </MudPaper>

                        @if (!string.IsNullOrEmpty(project.roles_sought))
                        {
                            <MudText Typo="Typo.h6" Class="mb-3"><b>Roles que buscamos completar:</b></MudText>
                            <div class="d-flex flex-wrap gap-2 mb-8">
                                @foreach (var role in project.roles_sought.Split(',', StringSplitOptions.RemoveEmptyEntries))
                                {
                                    <MudChip T="string" Color="Color.Info" Variant="Variant.Outlined" Size="Size.Large">@role.Trim()</MudChip>
                                }
                            </div>
                        }

                        <div class="d-flex justify-end pt-4 pb-2">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" 
                                       StartIcon="@Icons.Material.Filled.Mail" 
                                       Disabled="!project.is_open"
                                       OnClick="ContactCreator">
                                Contactar al Creador
                            </MudButton>
                        </div>
                    </MudTabPanel>

                    <MudTabPanel Text="Devlogs (Avances)" Icon="@Icons.Material.Filled.Article">
                        @if (isOwner && project.is_open)
                        {
                            <MudPaper Class="pa-4 mb-6" Elevation="2" Style="border-radius: 12px; background: rgba(0, 0, 0, 0.2);">
                                <MudText Typo="Typo.h6" Class="mb-4" Style="font-weight: 800;">Publicar un nuevo Avance</MudText>
                                
                                <MudTextField @bind-Value="newDevlogTitle" Label="Título del Avance" Variant="Variant.Outlined" Class="mb-3" />
                                <MudTextField @bind-Value="newDevlogContent" Label="Descripción detallada" Lines="4" Variant="Variant.Outlined" Class="mb-4" />
                                
                                <div class="d-flex align-center gap-4">
                                    <InputFile id="fileInput" OnChange="SelectMainImage" hidden accept=".jpg,.jpeg,.png" />
                                    <MudButton HtmlTag="label"
                                               Variant="Variant.Filled"
                                               Color="@(selectedFile != null ? Color.Success : Color.Secondary)"
                                               StartIcon="@(selectedFile != null ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.PhotoCamera)"
                                               for="fileInput">
                                        @(selectedFile != null ? selectedFile.Name : "Seleccionar Portada (Requerida)")
                                    </MudButton>

                                    <MudButton Variant="Variant.Filled" 
                                               Color="Color.Primary" 
                                               OnClick="UploadDevlog" 
                                               Disabled="@(isUploading || string.IsNullOrWhiteSpace(newDevlogTitle) || string.IsNullOrWhiteSpace(newDevlogContent) || selectedFile == null)"
                                               StartIcon="@Icons.Material.Filled.Send">
                                        @(isUploading ? "Publicando..." : "Publicar Devlog")
                                    </MudButton>
                                </div>
                            </MudPaper>
                            <MudDivider Class="mb-6"/>
                        }

                        @if (project.devlogs != null && project.devlogs.Any())
                        {
                            <MudGrid>
                                @foreach (var devlog in project.devlogs.OrderByDescending(d => d.created_at))
                                {
                                    <MudItem xs="12" md="6" lg="4">
                                        <MudCard Elevation="3" Class="devlog-card">
                                            <MudCardMedia Image="@devlog.main_image_url" Height="250" />
                                            <MudCardContent>
                                                <MudText Typo="Typo.h6" Style="font-weight: 700;">@devlog.title</MudText>
                                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2 d-block">@devlog.created_at.ToString("dd MMM yyyy HH:mm")</MudText>
                                                <MudText Typo="Typo.body2" Class="mb-4">@devlog.content</MudText>
                                                
                                                <div class="d-flex justify-space-between align-center mt-auto">
                                                    @if(isOwner) {
                                                        <InputFile id="@($"galleryInput_{devlog.id}")" OnChange="@(e => UploadGalleryImage(e, devlog.id))" hidden accept=".jpg,.jpeg,.png" />
                                                        <MudButton HtmlTag="label" for="@($"galleryInput_{devlog.id}")" Variant="Variant.Text" Color="Color.Info" Size="Size.Small" StartIcon="@Icons.Material.Filled.AddPhotoAlternate">Añadir Fotos</MudButton>
                                                    } else {
                                                        <span></span>
                                                    }
                                                    <MudBadge Content="@(devlog.reactions != null ? devlog.reactions.Count : 0)" Color="Color.Error" Overlap="true" Class="mx-2">
                                                        <MudIconButton Icon="@Icons.Material.Filled.LocalFireDepartment" Color="Color.Warning" Size="Size.Small" OnClick="@(() => AddReaction(devlog.id))" />
                                                    </MudBadge>
                                                </div>
                                                
                                                @if(devlog.images != null && devlog.images.Any())
                                                {
                                                    <MudDivider Class="my-3"/>
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2 d-block">Galería Adicional</MudText>
                                                    <div class="d-flex flex-wrap gap-2">
                                                        @foreach (var img in devlog.images)
                                                        {
                                                            <MudImage Src="@img.image_url" Width="100" Height="100" ObjectFit="ObjectFit.Cover" Class="rounded" />
                                                        }
                                                    </div>
                                                }
                                            </MudCardContent>
                                        </MudCard>
                                    </MudItem>
                                }
                            </MudGrid>
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">Aún no hay avances compartidos en este proyecto.</MudAlert>
                        }
                    </MudTabPanel>
                </MudTabs>
            </MudCardContent>

        </MudCard>
    }
</MudContainer>

@code {
    [Parameter]
    public int Id { get; set; }

    private ProjectDetailResponse? project;
    private bool isLoading = true;
    private bool isOwner = false; // Simulación de dueño
    private bool isUploading = false;
    private string? currentUserId;

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        try
        {
            project = await Http.GetFromJsonAsync<ProjectDetailResponse>($"projects/{Id}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error cargando proyecto: {ex.Message}");
            Snackbar.Add("Hubo un error al intentar cargar el proyecto", Severity.Error);
        }
        finally
        {
            isLoading = false;
            // Verificar si el usuario actual es el dueño
            if (project != null)
            {
                var authState = await AuthStateProvider.GetAuthenticationStateAsync();
                currentUserId = authState.User.FindFirst("user_id")?.Value;
                isOwner = currentUserId != null && currentUserId == project.owner_id.ToString();
            }
        }
    }

    private string newDevlogTitle = "";
    private string newDevlogContent = "";
    private IBrowserFile? selectedFile;

    private void SelectMainImage(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;

        var ext = Path.GetExtension(file.Name).ToLower();
        if (ext != ".jpg" && ext != ".jpeg" && ext != ".png")
        {
            Snackbar.Add("Solo se permiten archivos JPG y PNG.", Severity.Warning);
            return;
        }

        if (file.Size > 5 * 1024 * 1024)
        {
            Snackbar.Add("El archivo no debe pesar más de 5MB.", Severity.Warning);
            return;
        }

        selectedFile = file;
    }

    private async Task UploadDevlog()
    {
        if (selectedFile == null || string.IsNullOrWhiteSpace(newDevlogTitle) || string.IsNullOrWhiteSpace(newDevlogContent))
            return;

        isUploading = true;
        try
        {
            using var content = new MultipartFormDataContent();
            
            // Add Text Fields
            content.Add(new StringContent(newDevlogTitle), "title");
            content.Add(new StringContent(newDevlogContent), "content");
            content.Add(new StringContent(currentUserId ?? ""), "user_id");

            // Add Image File
            using var fileStream = selectedFile.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            using var streamContent = new StreamContent(fileStream);
            streamContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(selectedFile.ContentType);
            content.Add(streamContent, "main_image", selectedFile.Name);

            var response = await Http.PostAsync($"projects/{Id}/devlogs", content);
            
            if (response.IsSuccessStatusCode)
            {
                var newDevlog = await response.Content.ReadFromJsonAsync<DevlogResponse>();
                if (newDevlog != null)
                {
                    if (project != null) {
                        project.devlogs ??= new List<DevlogResponse>();
                        project.devlogs.Add(newDevlog);
                    }
                    
                    // Reset Form
                    newDevlogTitle = "";
                    newDevlogContent = "";
                    selectedFile = null;

                    Snackbar.Add("Devlog publicado con éxito", Severity.Success);
                }
            }
            else
            {
                var errorText = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Error al publicar: {errorText}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Upload error: {ex.Message}");
            Snackbar.Add("Error inesperado al publicar el devlog", Severity.Error);
        }
        finally
        {
            isUploading = false;
            StateHasChanged();
        }
    }

    private async Task UploadGalleryImage(InputFileChangeEventArgs e, int devlogId)
    {
        var file = e.File;
        if (file == null) return;

        var ext = Path.GetExtension(file.Name).ToLower();
        if (ext != ".jpg" && ext != ".jpeg" && ext != ".png")
        {
            Snackbar.Add("Solo se permiten archivos JPG y PNG.", Severity.Warning);
            return;
        }

        if (file.Size > 5 * 1024 * 1024)
        {
            Snackbar.Add("El archivo no debe pesar más de 5MB.", Severity.Warning);
            return;
        }

        try
        {
            using var content = new MultipartFormDataContent();
            content.Add(new StringContent(currentUserId ?? ""), "user_id");

            using var fileStream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            using var streamContent = new StreamContent(fileStream);
            streamContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(file.ContentType);
            content.Add(streamContent, "image", file.Name);

            var response = await Http.PostAsync($"projects/devlogs/{devlogId}/images", content);
            
            if (response.IsSuccessStatusCode)
            {
                var newImage = await response.Content.ReadFromJsonAsync<DevlogImageResponse>();
                if (newImage != null && project != null && project.devlogs != null)
                {
                    var targetDevlog = project.devlogs.FirstOrDefault(d => d.id == devlogId);
                    if (targetDevlog != null)
                    {
                        targetDevlog.images ??= new List<DevlogImageResponse>();
                        targetDevlog.images.Add(newImage);
                        StateHasChanged();
                    }
                }
                Snackbar.Add("Foto agregada a la galería", Severity.Success);
            }
            else
            {
                var errorText = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Error al subir foto: {errorText}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Upload gallery error: {ex.Message}");
            Snackbar.Add("Error inesperado al subir foto", Severity.Error);
        }
    }

    private void NavigateToEdit()
    {
        NavigationManager.NavigateTo($"/projects/{Id}/edit");
    }

    private void ContactCreator()
    {
        // Por ahora simulamos la acción como solicitó el usuario.
        Snackbar.Add("¡Mensaje enviado al creador exitosamente! Pronto te contactarán.", Severity.Success);
    }

    private async Task AddReaction(int devlogId)
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var userId = authState.User.FindFirst("user_id")?.Value ?? "1";
            
            var response = await Http.PostAsync($"projects/devlogs/{devlogId}/react?user_id={userId}&emoji=🔥", null);
            if (response.IsSuccessStatusCode)
            {
                // Refrescamos el proyecto
                project = await Http.GetFromJsonAsync<ProjectDetailResponse>($"projects/{Id}");
            }
            else
            {
                Snackbar.Add("No pudimos registrar tu reacción.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error reaccionando: {ex.Message}");
            Snackbar.Add("Error al conectar con la API de reacciones.", Severity.Error);
        }
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/projects");
    }

    private void OpenGalleryUpload(int devlogId)
    {
        // Esto invocaría un IJSRuntime para hacer click, per como no tenemos JS interop inyectado en este momento, usaremos el approach simple del HTMLLabel nativo en razor que acabamos de agregar. Esta funcion queda dummy ya que el Label se clickea nativamente.
    }

    // --- DTO CLASS EXCLUSIVA EN BLOQUE @CODE (REGLA ESTRICTA) ---
    public class ProjectDetailResponse
    {
        public int id { get; set; }
        public int owner_id { get; set; }
        public string owner_username { get; set; } = string.Empty;
        public string title { get; set; } = string.Empty;
        public string description { get; set; } = string.Empty;
        public string? roles_sought { get; set; }
        public bool is_open { get; set; }
        public DateTime created_at { get; set; }
        public List<DevlogResponse> devlogs { get; set; } = new();
    }

    public class DevlogResponse
    {
        public int id { get; set; }
        public int project_id { get; set; }
        public string title { get; set; } = string.Empty;
        public string content { get; set; } = string.Empty;
        public string main_image_url { get; set; } = string.Empty;
        public DateTime created_at { get; set; }
        public List<ReactionResponse> reactions { get; set; } = new();
        public List<DevlogImageResponse> images { get; set; } = new();
    }

    public class DevlogImageResponse
    {
        public int id { get; set; }
        public int devlog_id { get; set; }
        public string image_url { get; set; } = string.Empty;
        public DateTime created_at { get; set; }
    }

    public class ReactionResponse
    {
        public int id { get; set; }
        public int devlog_id { get; set; }
        public string emoji { get; set; } = string.Empty;
    }
}

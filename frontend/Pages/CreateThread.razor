@page "/threads/new"
@attribute [Authorize]
@inject HttpClient Http
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IJSRuntime _jsRuntime
@inject AuthenticationStateProvider AuthStateProvider
@using System.ComponentModel.DataAnnotations

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8">
    <div class="d-flex align-center mb-6">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Color="Color.Default" OnClick="GoBack" Class="mr-2" />
        <MudText Typo="Typo.h5"><b>Crear Nuevo Hilo</b></MudText>
    </div>

    <MudCard Elevation="4">
        <MudCardContent Class="pa-6">
            <EditForm Model="createModel" OnValidSubmit="HandleSubmit">
                <DataAnnotationsValidator />
                
                <MudTextField @bind-Value="createModel.title" 
                              Label="Título de la duda o discusión" 
                              Variant="Variant.Outlined" 
                              For="@(() => createModel.title)"
                              Required="true"
                              Class="mb-4" />

                <MudTextField @bind-Value="createModel.content" 
                               Label="Mensaje o descripción del hilo" 
                               Variant="Variant.Outlined" 
                               Lines="4"
                               For="@(() => createModel.content)"
                               Required="true"
                               Class="mb-6" />

                <div class="d-flex align-center mb-4">
                    <MudIcon Icon="@Icons.Material.Rounded.Code" Color="Color.Secondary" Class="mr-2" />
                    <MudText Typo="Typo.h6"><b>Fragmentos de Código</b></MudText>
                    <MudSpacer />
                    <MudButton StartIcon="@Icons.Material.Rounded.Add" 
                               Variant="Variant.Outlined" 
                               Color="Color.Secondary" 
                               Size="Size.Small"
                               OnClick="AddSnippet">Agregar Archivo</MudButton>
                </div>

                @if (createModel.snippets.Count == 0)
                {
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-6">
                        No has añadido ningún código. Puedes publicar solo el mensaje o añadir archivos.
                    </MudAlert>
                }

                @foreach (var snippet in createModel.snippets.Select((value, index) => new { value, index }))
                {
                    <MudCard Elevation="0" Class="mb-6" Style="border: 1px solid rgba(255,255,255,0.05); border-radius: 12px; background: rgba(15, 23, 42, 0.4);">
                        <MudCardContent>
                            <div class="d-flex align-center gap-4 mb-4">
                                <MudTextField @bind-Value="snippet.value.filename" 
                                               Label="Nombre del archivo (ej: main.py)" 
                                               Variant="Variant.Outlined" 
                                               Margin="Margin.Dense" />
                                
                                <MudSelect T="string" @bind-Value="snippet.value.language"
                                           Label="Lenguaje" 
                                           Variant="Variant.Outlined" 
                                           Margin="Margin.Dense"
                                           Style="min-width: 150px;">
                                    <MudSelectItem Value="@("csharp")">C#</MudSelectItem>
                                    <MudSelectItem Value="@("python")">Python</MudSelectItem>
                                    <MudSelectItem Value="@("javascript")">JS / TS</MudSelectItem>
                                    <MudSelectItem Value="@("html")">HTML</MudSelectItem>
                                    <MudSelectItem Value="@("sql")">SQL</MudSelectItem>
                                    <MudSelectItem Value="@("plaintext")">Texto</MudSelectItem>
                                </MudSelect>

                                <MudIconButton Icon="@Icons.Material.Rounded.Delete" 
                                               Color="Color.Error" 
                                               OnClick="@(() => RemoveSnippet(snippet.index))" />
                            </div>

                            <div style="height: 250px; border: 1px solid rgba(255,255,255,0.05); border-radius: 8px; overflow: hidden;">
                                <StandaloneCodeEditor @ref="editors[snippet.index]" 
                                                      Id="@($"editor-{snippet.index}")" 
                                                      ConstructionOptions="@((e) => EditorOptions(e, snippet.value.language))" 
                                                      CssClass="monaco-editor-container" />
                            </div>
                        </MudCardContent>
                    </MudCard>
                }


                <div class="d-flex justify-end">
                    <MudButton OnClick="GoBack" Variant="Variant.Text" Color="Color.Default" Class="mr-3">Cancelar</MudButton>
                    <MudButton ButtonType="ButtonType.Submit" 
                               Variant="Variant.Filled" 
                               Color="Color.Secondary" 
                               Disabled="@isSubmitting">
                        @if (isSubmitting)
                        {
                            <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true"/>
                            <MudText Class="ms-2">Enviando...</MudText>
                        }
                        else
                        {
                            <MudText>Publicar Hilo</MudText>
                        }
                    </MudButton>
                </div>
            </EditForm>
        </MudCardContent>
    </MudCard>
</MudContainer>

@code {
    private ThreadCreateRequest createModel = new();
    private bool isSubmitting = false;
    private Dictionary<int, StandaloneCodeEditor> editors = new();

    private StandaloneEditorConstructionOptions EditorOptions(StandaloneCodeEditor editor, string lang)
    {
        return new StandaloneEditorConstructionOptions
        {
            Language = lang,
            Theme = "vs-dark",
            AutomaticLayout = true,
            Minimap = new EditorMinimapOptions { Enabled = false }
        };
    }

    private void AddSnippet()
    {
        createModel.snippets.Add(new ThreadSnippetCreate { language = "csharp", filename = "nuevo_archivo.cs" });
    }

    private void RemoveSnippet(int index)
    {
        createModel.snippets.RemoveAt(index);
        editors.Remove(index);
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/threads");
    }

    private async Task HandleSubmit()
    {
        isSubmitting = true;
        
        try
        {
            // Extraer código de todos los editores
            for (int i = 0; i < createModel.snippets.Count; i++)
            {
                if (editors.TryGetValue(i, out var editor))
                {
                    createModel.snippets[i].code = await editor.GetValue();
                }
            }
            
            if (string.IsNullOrWhiteSpace(createModel.content))
            {
                Snackbar.Add("El mensaje principal no puede estar vacío.", Severity.Warning);
                isSubmitting = false;
                return;
            }
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var userId = authState.User.FindFirst("user_id")?.Value ?? "1"; // Fallback a 1 si no hay
            
            var response = await Http.PostAsJsonAsync($"threads/?user_id={userId}", createModel);
            
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("¡Hilo publicado exitosamente!", Severity.Success);
                NavigationManager.NavigateTo("/threads");
            }
            else
            {
                Snackbar.Add("Error al publicar el hilo.", Severity.Error);
            }
        }
        catch (Exception)
        {
            Snackbar.Add("Ocurrió un error inesperado al conectar con el servidor.", Severity.Error);
        }
        finally
        {
            isSubmitting = false;
        }
    }

    // --- DTO CLASSES EN BLOQUE @CODE ---
    public class ThreadCreateRequest
    {
        [Required(ErrorMessage = "Debes ingresar un título.")]
        public string title { get; set; } = string.Empty;

        [Required(ErrorMessage = "El contenido no puede estar vacío.")]
        public string content { get; set; } = string.Empty;

        public List<ThreadSnippetCreate> snippets { get; set; } = new();
    }

    public class ThreadSnippetCreate
    {
        public string filename { get; set; } = "archivo.cs";
        public string language { get; set; } = "csharp";
        public string code { get; set; } = string.Empty;
    }
}

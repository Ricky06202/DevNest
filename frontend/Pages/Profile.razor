@page "/profile"
@attribute [Authorize]
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-10">
    <MudCard Elevation="0" Class="neon-card pa-6">
        <MudCardHeader Class="d-flex flex-column align-center pb-0 mt-4">
            <div class="avatar-container mb-4">
                <MudAvatar Color="Color.Secondary" Style="width: 120px; height: 120px; font-size: 3.5rem; background: rgba(59, 130, 246, 0.1); border: 2px solid rgba(59, 130, 246, 0.3);">
                    <MudIcon Icon="@Icons.Material.Filled.Person" Style="font-size: 4rem;" />
                </MudAvatar>
                <div class="avatar-glow"></div>
            </div>
            <MudText Typo="Typo.h4" Style="font-weight: 800; color: #f8fafc; letter-spacing: -1px;">@username</MudText>
            <MudText Typo="Typo.body1" Style="color: #3b82f6; font-family: 'JetBrains Mono'; font-size: 0.9rem;">@email</MudText>
        </MudCardHeader>

        <MudCardContent Class="text-center">
            @if (isLoading)
            {
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="mt-4" />
            }
            else
            {
                <div class="d-flex justify-center gap-2 mt-4 mb-8">
                    <div class="tech-pill">
                        <MudIcon Icon="@Icons.Material.Rounded.Star" Size="Size.Small" Class="mr-1" />
                        Junior / Mid
                    </div>
                    <div class="tech-pill" style="border-color: rgba(16, 185, 129, 0.2); color: #34d399;">
                        <MudIcon Icon="@Icons.Material.Rounded.Verified" Size="Size.Small" Class="mr-1" />
                        Verificado
                    </div>
                </div>

                <MudDivider Style="background-color: rgba(255,255,255,0.05);" />

                <div class="d-flex flex-column align-start mx-auto mt-8" style="max-width: 320px;">
                    <MudText Typo="Typo.subtitle2" Style="color: #64748b; text-transform: uppercase; letter-spacing: 1px; font-weight: 700;">Biografía</MudText>
                    <MudText Typo="Typo.body2" Class="mt-2 mb-6 text-left" Style="color: #94a3b8; line-height: 1.6;">
                        Desarrollador enfocado en @(username.ToLower().Contains("dev") ? "soluciones Fullstack" : "crear experiencias increíbles"). Apasionado por la arquitectura limpia y la colaboración en DevNest.
                    </MudText>

                    <MudText Typo="Typo.subtitle2" Style="color: #64748b; text-transform: uppercase; letter-spacing: 1px; font-weight: 700;">Conexiones</MudText>
                    <div class="d-flex align-center mt-3 w-100 p-2" style="background: rgba(255,255,255,0.02); border-radius: 8px;">
                        <MudIcon Icon="@Icons.Custom.Brands.GitHub" Color="Color.Default" Size="Size.Small" Class="mr-3" />
                        <MudText Typo="Typo.body2" Style="color: #f8fafc; font-family: 'JetBrains Mono';">github.com/@username.ToLower()</MudText>
                        <MudSpacer />
                        <MudIcon Icon="@Icons.Material.Rounded.OpenInNew" Size="Size.Small" Style="color: #475569;" />
                    </div>
                </div>
            }
        </MudCardContent>

        <MudCardActions Class="d-flex justify-center pb-8 mt-4">
            <MudButton Variant="Variant.Filled" 
                       Color="Color.Primary" 
                       Size="Size.Large" 
                       OnClick="ShowComingSoonMsg" 
                       StartIcon="@Icons.Material.Rounded.EditNote"
                       Class="mud-button-filled px-8"
                       Style="border-radius: 12px; font-weight: 700; text-transform: none;">
                Configurar Perfil
            </MudButton>
        </MudCardActions>
    </MudCard>
</MudContainer>

<style>
    .avatar-container {
        position: relative;
        display: inline-block;
    }
    .avatar-glow {
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background: radial-gradient(circle, rgba(59, 130, 246, 0.4) 0%, transparent 70%);
        filter: blur(20px);
        z-index: -1;
        opacity: 0.6;
    }
    .tech-pill {
        display: flex;
        align-items: center;
        padding: 4px 12px;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
        color: #94a3b8;
    }
</style>

@code {
    private bool isLoading = true;
    private string username = "Usuario";
    private string email = "cargando@devnest.com";

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user.Identity is not null && user.Identity.IsAuthenticated)
            {
                // Extraer los claims que inyectamos manualmente en CustomAuthenticationStateProvider
                username = user.Identity.Name ?? user.FindFirst(c => c.Type == "sub")?.Value ?? "Desconocido";
                email = user.FindFirst(c => c.Type == System.Security.Claims.ClaimTypes.Email)?.Value 
                        ?? $"{username.ToLower()}@devnest.local";
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error leyendo token JWT: {ex.Message}");
            Snackbar.Add("Error al cargar los datos del perfil.", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ShowComingSoonMsg()
    {
        Snackbar.Add("¡Edición de perfil próximamente disponible!", Severity.Info);
    }
}

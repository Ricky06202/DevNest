@page "/profile"
@attribute [Authorize]
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-10">
    <MudCard Elevation="4">
        <MudCardHeader Class="d-flex justify-center pb-0 mt-4">
            <MudAvatar Color="Color.Secondary" Style="width: 100px; height: 100px; font-size: 3rem;">
                <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Large" />
            </MudAvatar>
        </MudCardHeader>

        <MudCardContent Class="text-center">
            @if (isLoading)
            {
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="mt-4" />
            }
            else
            {
                <MudText Typo="Typo.h4" Class="mt-4 mb-1"><b>@username</b></MudText>
                <MudText Typo="Typo.body1" Color="Color.Primary" Class="mb-6">@email</MudText>

                <MudDivider Class="mb-6" />

                <div class="d-flex flex-column align-start mx-auto" style="max-width: 300px;">
                    <MudText Typo="Typo.h6" Class="mb-2"><b>Sobre Mí</b></MudText>
                    <MudText Typo="Typo.body2" Class="mb-4 text-left" Color="Color.Secondary">
                        ¡Hola! Soy un desarrollador apasionado que acaba de unirse a DevNest. Listo para colaborar en proyectos increíbles y aprender de la comunidad.
                    </MudText>

                    <div class="d-flex align-center mb-2">
                        <MudIcon Icon="@Icons.Material.Filled.Star" Color="Color.Warning" Size="Size.Small" Class="mr-2" />
                        <MudText Typo="Typo.body2"><b>Experiencia:</b> Junior / Mid</MudText>
                    </div>

                    <div class="d-flex align-center mb-6">
                        <MudIcon Icon="@Icons.Custom.Brands.GitHub" Color="Color.Default" Size="Size.Small" Class="mr-2" />
                        <MudText Typo="Typo.body2"><b>GitHub:</b> @($"github.com/{username.ToLower()}")</MudText>
                    </div>
                </div>
            }
        </MudCardContent>

        <MudCardActions Class="d-flex justify-center pb-6">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" OnClick="ShowComingSoonMsg" StartIcon="@Icons.Material.Filled.Edit">
                Editar Perfil
            </MudButton>
        </MudCardActions>
    </MudCard>
</MudContainer>

@code {
    private bool isLoading = true;
    private string username = "Usuario";
    private string email = "cargando@devnest.com";

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user.Identity is not null && user.Identity.IsAuthenticated)
            {
                // Extraer los claims que inyectamos manualmente en CustomAuthenticationStateProvider
                username = user.Identity.Name ?? user.FindFirst(c => c.Type == "sub")?.Value ?? "Desconocido";
                email = user.FindFirst(c => c.Type == System.Security.Claims.ClaimTypes.Email)?.Value 
                        ?? $"{username.ToLower()}@devnest.local";
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error leyendo token JWT: {ex.Message}");
            Snackbar.Add("Error al cargar los datos del perfil.", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ShowComingSoonMsg()
    {
        Snackbar.Add("¡Edición de perfil próximamente disponible!", Severity.Info);
    }
}

@page "/threads"
@attribute [Authorize]
@inject HttpClient Http
@inject NavigationManager NavigationManager

<div class="d-flex justify-space-between align-center mb-6 mt-4">
    <MudText Typo="Typo.h4" Color="Color.Secondary"><b>Muro de Código</b></MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="NavigateToCreate">Nuevo Hilo</MudButton>
</div>

@if (threads == null)
{
    <MudProgressCircular Color="Color.Secondary" Indeterminate="true" Class="mt-5" />
}
else if (!threads.Any())
{
    <MudAlert Severity="Severity.Info" Class="mt-5">El gran muro del código está vacío. ¡Publica la primera charla técnica!</MudAlert>
}
else
{
    <MudGrid>
        @foreach (var thread in threads)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudCard Elevation="3" Class="h-100 d-flex flex-column">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6"><b>@thread.title</b></MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-1">
                                Publicado por User ID #@thread.author_id el @thread.created_at.ToString("dd/MMM/yyyy")
                            </MudText>
                            <MudChip T="string" Color="Color.Dark" Size="Size.Small">@thread.code_language</MudChip>
                        </CardHeaderContent>
                    </MudCardHeader>
                    
                    <MudCardContent Class="flex-grow-1">
                        <!-- Mostraremos solo un extracto del contenido para no romper el layout -->
                        <MudText Typo="Typo.body1" Class="mb-4">
                            @(thread.content.Length > 100 ? thread.content.Substring(0, 100) + "..." : thread.content)
                        </MudText>
                    </MudCardContent>
                    
                    <MudCardActions Class="mt-auto pa-4">
                        <MudButton Variant="Variant.Text" Color="Color.Secondary" FullWidth="true" Href="@($"/threads/{thread.id}")">Ver Hilo Completo</MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}

@code {
    private List<ThreadResponse>? threads;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            threads = await Http.GetFromJsonAsync<List<ThreadResponse>>("api/threads/");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error cargando hilos: {ex.Message}");
            threads = new List<ThreadResponse>();
        }
    }

    private void NavigateToCreate()
    {
        NavigationManager.NavigateTo("/threads/new");
    }

    // --- DTO CLASSES EN BLOQUE @CODE ---
    public class ThreadResponse
    {
        public int id { get; set; }
        public int author_id { get; set; }
        public string title { get; set; } = string.Empty;
        public string content { get; set; } = string.Empty;
        public string code_language { get; set; } = string.Empty;
        public DateTime created_at { get; set; }
    }
}

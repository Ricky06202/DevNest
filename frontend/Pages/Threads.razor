@page "/threads"
@attribute [Authorize]
@inject HttpClient Http
@inject NavigationManager NavigationManager

<div class="d-flex justify-space-between align-center mb-8 mt-4">
    <div class="d-flex align-center">
        <div style="width: 40px; height: 40px; background: rgba(139, 92, 246, 0.1); border-radius: 8px; display: flex; align-items: center; justify-content: center;" class="mr-4">
            <MudIcon Icon="@Icons.Material.Rounded.Code" Color="Color.Secondary" />
        </div>
        <div>
            <MudText Typo="Typo.h4" Style="@($"font-weight: 800; color: {(IsDarkMode ? "#f8fafc" : "#0f172a")};")">Muro de Código</MudText>
            <MudText Typo="Typo.caption" Style="@($"color: {(IsDarkMode ? "#64748b" : "#475569")}; font-family: 'JetBrains Mono';")">Intercambio de conocimiento técnico</MudText>
        </div>
    </div>
    <MudButton Variant="Variant.Filled" Color="Color.Secondary" StartIcon="@Icons.Material.Rounded.Add" OnClick="NavigateToCreate" Class="mud-button-filled">
        Nuevo Hilo
    </MudButton>
</div>

<!-- Barra de Búsqueda -->
<div class="mb-8 p-4" style="@($"background: {(IsDarkMode ? "rgba(15, 23, 42, 0.5)" : "rgba(255, 255, 255, 0.5)")}; border: 1px solid {(IsDarkMode ? "rgba(255,255,255,0.05)" : "rgba(0,0,0,0.05)")}; border-radius: 12px;")">
    <MudTextField @bind-Value="searchQuery" 
                  Placeholder="Buscar por título, contenido o autor..." 
                  Adornment="Adornment.Start" 
                  AdornmentIcon="@Icons.Material.Filled.Search" 
                  Variant="Variant.Outlined" 
                  Immediate="true"
                  OnKeyUp="FilterThreads"
                  Clearable="true" />
</div>

@if (allThreads == null)
{
    <MudProgressCircular Color="Color.Secondary" Indeterminate="true" Class="mt-5" />
}
else if (!allThreads.Any())
{
    <MudAlert Severity="Severity.Info" Class="mt-5">El gran muro del código está vacío. ¡Publica la primera charla técnica!</MudAlert>
}
else if (!filteredThreads.Any())
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-5">No se encontraron hilos para tu búsqueda.</MudAlert>
}
else
{
    <MudGrid Spacing="4">
        @foreach (var thread in filteredThreads)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudCard Elevation="0" Class="neon-card h-100 d-flex flex-column" Style="border-top: 4px solid #8b5cf6 !important;">
                    <MudCardHeader Class="pb-2">
                        <CardHeaderContent>
                            <div class="d-flex justify-space-between align-center mb-1">
                                <MudText Typo="Typo.h6" Style="@($"font-weight: 700; color: {(IsDarkMode ? "#f8fafc" : "#0f172a")};")">@thread.title</MudText>
                                <div style="@($"font-size: 0.65rem; font-family: 'JetBrains Mono'; padding: 2px 6px; background: rgba(139, 92, 246, 0.1); color: {(IsDarkMode ? "#a78bfa" : "#7c3aed")}; border: 1px solid rgba(139, 92, 246, 0.2); border-radius: 4px;")">
                                    @(thread.snippets.Count == 0 ? "POST" : $"{thread.snippets.Count} ARCHIVOS")
                                </div>
                            </div>
                            <div class="d-flex align-center">
                                <MudIcon Icon="@Icons.Material.Rounded.Person" Size="Size.Small" Style="color: #64748b;" Class="mr-1" />
                                <MudText Typo="Typo.caption" Style="@($"color: {(IsDarkMode ? "#64748b" : "#64748b")};")">
                                    @thread.author_username
                                </MudText>
                                <MudText Typo="Typo.caption" Class="mx-2" Style="color: #64748b;">•</MudText>
                                <MudText Typo="Typo.caption" Style="@($"color: {(IsDarkMode ? "#64748b" : "#64748b")};")">
                                    @thread.created_at.ToString("dd MMM yyyy")
                                </MudText>
                                @if (thread.snippets.Count > 0)
                                {
                                    <MudTooltip Text="@(string.Join(", ", thread.snippets.Select(s => s.filename)))">
                                        <MudIcon Icon="@Icons.Material.Rounded.FilePresent" Size="Size.Small" Color="Color.Secondary" Class="ml-2" />
                                    </MudTooltip>
                                }
                            </div>
                        </CardHeaderContent>
                    </MudCardHeader>
                    
                    <MudCardContent Class="pt-2 flex-grow-1">
                        <MudText Typo="Typo.body2" Style="@($"color: {(IsDarkMode ? "#94a3b8" : "#475569")}; line-height: 1.6;")">
                            @(thread.content.Length > 120 ? thread.content.Substring(0, 120) + "..." : thread.content)
                        </MudText>
                    </MudCardContent>
                    
                    <MudCardActions Class="pa-4">
                        <MudButton Variant="Variant.Text" Color="Color.Secondary" FullWidth="true" 
                                   StartIcon="@Icons.Material.Rounded.ReadMore"
                                   Style="text-transform: none; font-weight: 600;"
                                   Href="@($"/threads/{thread.id}")">
                            Abrir Código
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}

@code {
    [CascadingParameter(Name = "IsDarkMode")]
    public bool IsDarkMode { get; set; }

    private List<ThreadResponse>? allThreads;
    private List<ThreadResponse> filteredThreads = new();
    private string searchQuery = "";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            allThreads = await Http.GetFromJsonAsync<List<ThreadResponse>>("threads/");
            if (allThreads != null)
            {
                filteredThreads = allThreads;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error cargando hilos: {ex.Message}");
            allThreads = new List<ThreadResponse>();
        }
    }

    private void FilterThreads()
    {
        if (string.IsNullOrWhiteSpace(searchQuery) || allThreads == null)
        {
            filteredThreads = allThreads ?? new();
        }
        else
        {
            var lowerQuery = searchQuery.ToLower();
            filteredThreads = allThreads.Where(t => 
                t.title.ToLower().Contains(lowerQuery) ||
                (t.content != null && t.content.ToLower().Contains(lowerQuery)) ||
                t.author_username.ToLower().Contains(lowerQuery)
            ).ToList();
        }
    }

    private void NavigateToCreate()
    {
        NavigationManager.NavigateTo("/threads/new");
    }

    public class ThreadResponse
    {
        public int id { get; set; }
        public int author_id { get; set; }
        public string author_username { get; set; } = string.Empty;
        public string title { get; set; } = string.Empty;
        public string content { get; set; } = string.Empty;
        public List<ThreadSnippetResponse> snippets { get; set; } = new();
        public DateTime created_at { get; set; }
    }

    public class ThreadSnippetResponse
    {
        public string filename { get; set; } = string.Empty;
        public string language { get; set; } = string.Empty;
    }
}

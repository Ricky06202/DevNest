@page "/projects"
@attribute [Authorize]
@inject HttpClient Http
@inject NavigationManager NavigationManager

<div class="d-flex justify-space-between align-center mb-6 mt-4">
    <MudText Typo="Typo.h4" Color="Color.Primary"><b>Radar de Proyectos</b></MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.Add" OnClick="NavigateToCreate">Publicar Proyecto</MudButton>
</div>

@if (projects == null)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="mt-5" />
}
else if (!projects.Any())
{
    <MudAlert Severity="Severity.Info" Class="mt-5">Aún no hay proyectos en el radar. ¡Sé el primero en buscar equipo!</MudAlert>
}
else
{
    <MudGrid>
        @foreach (var project in projects)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudCard Elevation="3" Class="h-100 d-flex flex-column">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <div class="d-flex justify-space-between align-center mb-2">
                                <MudText Typo="Typo.h6"><b>@project.title</b></MudText>
                                @if (project.is_open)
                                {
                                    <MudChip T="string" Color="Color.Success" Size="Size.Small">Abierto</MudChip>
                                }
                                else
                                {
                                    <MudChip T="string" Color="Color.Error" Size="Size.Small">Cerrado</MudChip>
                                }
                            </div>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Publicado el: @project.created_at.ToString("dd/MMM/yyyy")</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    
                    <MudCardContent Class="flex-grow-1">
                        <MudText Typo="Typo.body1" Class="mb-4">@project.description</MudText>
                        
                        @if (!string.IsNullOrEmpty(project.roles_sought))
                        {
                            <MudText Typo="Typo.subtitle2" Class="mt-2"><b>Roles Buscados:</b></MudText>
                            <div class="d-flex flex-wrap gap-1 mt-1">
                                <!-- Dividimos el string asumiendo que vienen por comas -->
                                @foreach (var role in project.roles_sought.Split(',', StringSplitOptions.RemoveEmptyEntries))
                                {
                                    <MudChip T="string" Color="Color.Info" Size="Size.Small" Variant="Variant.Outlined">@role.Trim()</MudChip>
                                }
                            </div>
                        }
                    </MudCardContent>
                    
                    <MudCardActions Class="mt-auto pa-4">
                        <MudButton Variant="Variant.Text" Color="Color.Primary" FullWidth="true" Disabled="!project.is_open">Aplicar / Ver Detalle</MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}

@code {
    private List<ProjectResponse>? projects;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // El HttpClient de Program.cs ya inyecta el token Bearer y apunta a :8000
            projects = await Http.GetFromJsonAsync<List<ProjectResponse>>("api/projects/");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error cargando proyectos: {ex.Message}");
            projects = new List<ProjectResponse>(); // Evitar null spinner si falla
        }
    }

    private void NavigateToCreate()
    {
        NavigationManager.NavigateTo("/projects/new");
    }

    // --- DTO CLASSES EXCLUSIVOS EN BLOQUE @CODE (REGLA ESTRICTA) ---
    public class ProjectResponse
    {
        public int id { get; set; }
        public int owner_id { get; set; }
        public string title { get; set; } = string.Empty;
        public string description { get; set; } = string.Empty;
        public string? roles_sought { get; set; }
        public bool is_open { get; set; }
        public DateTime created_at { get; set; }
    }
}

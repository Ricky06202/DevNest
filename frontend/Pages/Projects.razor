@page "/projects"
@attribute [Authorize]
@inject HttpClient Http
@inject NavigationManager NavigationManager

<div class="d-flex justify-space-between align-center mb-6 mt-4">
    <div class="d-flex align-center">
        <div style="width: 40px; height: 40px; background: rgba(59, 130, 246, 0.1); border-radius: 8px; display: flex; align-items: center; justify-content: center;" class="mr-4">
            <MudIcon Icon="@Icons.Material.Rounded.Radar" Color="Color.Primary" />
        </div>
        <div>
            <MudText Typo="Typo.h4" Style="@($"font-weight: 800; color: {(IsDarkMode ? "#f8fafc" : "#0f172a")};")">Radar de Proyectos</MudText>
            <MudText Typo="Typo.caption" Style="@($"color: {(IsDarkMode ? "#64748b" : "#475569")}; font-family: 'JetBrains Mono';")">@projects?.Count() sistemas detectados en la red</MudText>
        </div>
    </div>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Rounded.Add" OnClick="NavigateToCreate" Class="mud-button-filled">
        Publicar Proyecto
    </MudButton>
</div>

@if (projects == null)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="mt-5" />
}
else if (!projects.Any())
{
    <MudAlert Severity="Severity.Info" Class="mt-5">Aún no hay proyectos en el radar. ¡Sé el primero en buscar equipo!</MudAlert>
}
else
{
    <MudGrid Spacing="4">
        @foreach (var project in projects)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudCard Elevation="0" Class="neon-card h-100 d-flex flex-column" Style="border-top: 4px solid #3b82f6 !important;">
                    <MudCardHeader Class="pb-0">
                        <CardHeaderContent>
                            <div class="d-flex justify-space-between align-center mb-2">
                                <MudText Typo="Typo.h6" Style="@($"font-weight: 700; color: {(IsDarkMode ? "#f8fafc" : "#0f172a")};")">@project.title</MudText>
                                <div style="width: 10px; height: 10px; border-radius: 50%; background: @(project.is_open ? "#10b981" : "#ef4444"); box-shadow: 0 0 10px @(project.is_open ? "#10b981" : "#ef4444");"></div>
                            </div>
                        </CardHeaderContent>
                    </MudCardHeader>
                    
                    <MudCardContent Class="pt-2 flex-grow-1">
                        <MudText Typo="Typo.body2" Style="@($"color: {(IsDarkMode ? "#94a3b8" : "#475569")}; line-height: 1.6;")" Class="mb-4">
                            @project.description
                        </MudText>
                        
                        <div class="d-flex flex-wrap gap-2 mt-auto">
                            @if (!string.IsNullOrEmpty(project.roles_sought))
                            {
                                @foreach (var role in project.roles_sought.Split(',', StringSplitOptions.RemoveEmptyEntries))
                                {
                                    <div style="@($"font-size: 0.7rem; padding: 2px 8px; background: rgba(59, 130, 246, 0.1); color: {(IsDarkMode ? "#60a5fa" : "#2563eb")}; border: 1px solid rgba(59, 130, 246, 0.2); border-radius: 4px;")">
                                        @role.Trim().ToUpper()
                                    </div>
                                }
                            }
                        </div>
                    </MudCardContent>
                    
                    <MudCardActions Class="pa-4 pt-0">
                        <MudDivider DividerType="DividerType.Middle" Class="mb-4" Style="@($"background: {(IsDarkMode ? "rgba(255,255,255,0.05)" : "rgba(0,0,0,0.05)")};")" />
                        <div class="d-flex justify-space-between align-center w-100">
                            <MudText Typo="Typo.caption" Style="@($"color: {(IsDarkMode ? "#64748b" : "#64748b")};")">@project.created_at.ToString("dd MMM")</MudText>
                            <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Primary" EndIcon="@Icons.Material.Rounded.ArrowForward" 
                                       Style="text-transform: none; font-weight: 600;"
                                       Href="@($"/projects/{project.id}")">
                                Detalles
                            </MudButton>
                        </div>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}

@code {
    [CascadingParameter(Name = "IsDarkMode")]
    public bool IsDarkMode { get; set; }

    private List<ProjectResponse>? projects;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            projects = await Http.GetFromJsonAsync<List<ProjectResponse>>("api/projects/");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error cargando proyectos: {ex.Message}");
            projects = new List<ProjectResponse>();
        }
    }

    private void NavigateToCreate()
    {
        NavigationManager.NavigateTo("/projects/new");
    }

    public class ProjectResponse
    {
        public int id { get; set; }
        public int owner_id { get; set; }
        public string title { get; set; } = string.Empty;
        public string description { get; set; } = string.Empty;
        public string? roles_sought { get; set; }
        public bool is_open { get; set; }
        public DateTime created_at { get; set; }
    }
}

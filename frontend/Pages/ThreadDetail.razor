@page "/threads/{Id:int}"
@attribute [Authorize]
@inject HttpClient Http
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider
@using System.ComponentModel.DataAnnotations
@using BlazorMonaco
@using BlazorMonaco.Editor

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">
    <MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Color="Color.Default" OnClick="GoBack" Class="mb-4">Volver al Muro</MudButton>

    @if (isLoading)
    {
        <div class="d-flex justify-center mt-10">
            <MudProgressCircular Color="Color.Secondary" Indeterminate="true" Size="Size.Large" />
        </div>
    }
    else if (thread == null)
    {
        <MudAlert Severity="Severity.Error" Class="mt-5">No se pudo cargar el hilo o no existe.</MudAlert>
    }
    else
    {
        <!-- Hilo Principal -->
        <MudCard Elevation="4" Class="mb-8">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h4" Color="Color.Secondary"><b>@thread.title</b></MudText>
                    <div class="d-flex align-center mt-2">
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mr-3 d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Class="mr-1" />
                            @thread.author_username
                            @if (thread.author_karma > 0)
                            {
                                <MudChip T="string" Size="Size.Small" Color="@(thread.author_karma >= 100 ? Color.Warning : Color.Surface)" Icon="@Icons.Material.Filled.LocalFireDepartment" Variant="Variant.Text" Style="font-size: 0.70rem; padding: 0 4px; height: 20px; margin-left: 4px;">@thread.author_karma</MudChip>
                            }
                        </MudText>
                        <MudText Typo="Typo.caption">@thread.created_at.ToString("dd MMM yyyy HH:mm")</MudText>
                        <MudSpacer />
                        <MudChip T="string" Color="Color.Dark" Size="Size.Small">
                            @(thread.snippets.Any() ? $"{thread.snippets.Count} Archivos" : "Discusión")
                        </MudChip>
                    </div>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudText Typo="Typo.body1" Style="white-space: pre-wrap; color: #f8fafc; font-size: 1.1rem; line-height: 1.6;" Class="mb-6">
                    @thread.content
                </MudText>

                @if (thread.snippets != null && thread.snippets.Any())
                {
                    <div class="d-flex flex-column gap-6">
                        @foreach (var snippet in thread.snippets.Select((value, index) => new { value, index }))
                        {
                            <div class="snippet-block">
                                <div style="background: rgba(15, 23, 42, 0.8); padding: 8px 16px; border: 1px solid rgba(255,255,255,0.05); border-bottom: none; border-radius: 8px 8px 0 0; display: flex; align-items: center; justify-content: space-between;">
                                    <div class="d-flex align-center gap-2">
                                        <MudIcon Icon="@Icons.Material.Rounded.Code" Size="Size.Small" Color="Color.Secondary" />
                                        <MudText Typo="Typo.caption" Style="color: #f8fafc; font-family: 'JetBrains Mono';">@snippet.value.filename</MudText>
                                    </div>
                                    <MudChip T="string" Size="Size.Small" Color="Color.Dark" Variant="Variant.Text">@snippet.value.language.ToUpper()</MudChip>
                                </div>
                                <div style="height: 350px; border: 1px solid rgba(255,255,255,0.05); border-radius: 0 0 8px 8px; overflow: hidden; position: relative;">
                                    <StandaloneCodeEditor @ref="detailEditors[snippet.index]" 
                                                          Id="@($"detail-editor-{snippet.index}")" 
                                                          ConstructionOptions="@((e) => DetailEditorOptions(e, snippet.value))" 
                                                          CssClass="monaco-editor-container" />
                                </div>
                            </div>
                        }
                    </div>
                }
            </MudCardContent>
        </MudCard>

        <MudText Typo="Typo.h5" Class="mb-4"><b>Respuestas (@thread.replies?.Count)</b></MudText>

        <!-- Lista de Respuestas -->
        @if (thread.replies != null && thread.replies.Any())
        {
            <div class="d-flex flex-column gap-4 mb-8">
                @foreach (var reply in thread.replies)
                {
                    <MudPaper Elevation="2" Class="pa-4" Style="@(reply.is_solution ? "border-left: 4px solid var(--mud-palette-success);" : "")">
                        <div class="d-flex justify-space-between align-center mb-2">
                            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="d-flex align-center">
                                <b>@reply.author_username</b> 
                                @if (reply.author_karma > 0)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="@(reply.author_karma >= 100 ? Color.Warning : Color.Surface)" Icon="@Icons.Material.Filled.LocalFireDepartment" Variant="Variant.Text" Style="font-size: 0.70rem; padding: 0 4px; height: 20px; margin-left: 4px; margin-right: 4px;">@reply.author_karma</MudChip>
                                }
                                - @reply.created_at.ToString("dd MMM yyyy HH:mm")
                            </MudText>
                            <div>
                                @if (reply.is_solution)
                                {
                                    <MudChip T="string" Color="Color.Success" Size="Size.Small" Icon="@Icons.Material.Filled.CheckCircle">Solución Óptima</MudChip>
                                }
                                else
                                {
                                    <MudTooltip Text="Marcar como Solución">
                                        <MudIconButton Icon="@Icons.Material.Filled.Star" Color="Color.Warning" Size="Size.Small" OnClick="@(() => MarkAsSolution(reply.id))" />
                                    </MudTooltip>
                                }
                            </div>
                        </div>
                        <MudText Typo="Typo.body1" Style="white-space: pre-wrap;" Class="@(string.IsNullOrEmpty(reply.code_snippet) ? "" : "mb-3")">@reply.content</MudText>
                        
                        @if (!string.IsNullOrEmpty(reply.code_snippet))
                        {
                            <div style="height: 250px; border: 1px solid rgba(255,255,255,0.05); border-radius: 8px; overflow: hidden; position: relative;">
                                <StandaloneCodeEditor @ref="replyEditors[reply.id]" 
                                                      Id="@($"reply-editor-{reply.id}")" 
                                                      ConstructionOptions="@((e) => ReplyEditorOptions(e, reply.code_snippet))" 
                                                      CssClass="monaco-editor-container" />
                            </div>
                        }
                    </MudPaper>
                }
            </div>
        }
        else
        {
            <MudAlert Severity="Severity.Normal" Class="mb-8">No hay respuestas aún. ¡Sé el primero en ayudar!</MudAlert>
        }

        <!-- Formulario de Nueva Respuesta -->
        <MudCard Elevation="2">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6"><b>Agregar Respuesta</b></MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <EditForm Model="replyModel" OnValidSubmit="SubmitReply">
                    <DataAnnotationsValidator />
                    <MudTextField @bind-Value="replyModel.content" 
                                  Label="Escribe tu sugerencia o feedback aquí..." 
                                  Variant="Variant.Outlined" 
                                  Lines="3"
                                  For="@(() => replyModel.content)"
                                  Required="true"
                                  Class="mb-4" />
                                  
                    <div class="d-flex align-center mb-4">
                        <MudSwitch @bind-Value="includeCode" Color="Color.Secondary" Label="Adjuntar Código (Nivel Dios)" />
                    </div>

                    @if (includeCode)
                    {
                        <div class="mb-4" style="height: 250px; border: 1px solid rgba(255,255,255,0.05); border-radius: 8px; overflow: hidden;">
                            <StandaloneCodeEditor @ref="replyInputEditor" 
                                                  Id="reply-input-editor" 
                                                  ConstructionOptions="ReplyInputEditorOptions" 
                                                  CssClass="monaco-editor-container" />
                        </div>
                    }

                    <div class="d-flex justify-end">
                        <MudButton ButtonType="ButtonType.Submit" 
                                   Variant="Variant.Filled" 
                                   Color="Color.Primary" 
                                   Disabled="@isReplying">
                            @if (isReplying)
                            {
                                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true"/>
                                <MudText Class="ms-2">Enviando...</MudText>
                            }
                            else
                            {
                                <MudText>Responder Hilo</MudText>
                            }
                        </MudButton>
                    </div>
                </EditForm>
            </MudCardContent>
        </MudCard>
    }
</MudContainer>

@code {
    [Parameter]
    public int Id { get; set; }

    private ThreadDetailResponse? thread;
    private bool isLoading = true;
    
    // Reply form
    private ReplyCreateRequest replyModel = new();
    private bool isReplying = false;

    // Monaco Editors for snippets
    private Dictionary<int, StandaloneCodeEditor> detailEditors = new();
    private Dictionary<int, StandaloneCodeEditor> replyEditors = new();
    
    private bool includeCode = false;
    private StandaloneCodeEditor? replyInputEditor;

    protected override async Task OnInitializedAsync()
    {
        await LoadThreadData();
    }

    private async Task LoadThreadData()
    {
        isLoading = true;
        try
        {
            thread = await Http.GetFromJsonAsync<ThreadDetailResponse>($"threads/{Id}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error cargando el hilo: {ex.Message}");
            Snackbar.Add("Error al cargar el hilo de código.", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }

    private StandaloneEditorConstructionOptions DetailEditorOptions(StandaloneCodeEditor editor, ThreadSnippetResponse snippet)
    {
        return new StandaloneEditorConstructionOptions
        {
            Language = snippet.language.ToLower() == "c#" ? "csharp" : snippet.language.ToLower(),
            Theme = "vs-dark",
            Value = snippet.code,
            ReadOnly = true,
            AutomaticLayout = true,
            Minimap = new EditorMinimapOptions { Enabled = false },
            ScrollBeyondLastLine = false
        };
    }

    private StandaloneEditorConstructionOptions ReplyEditorOptions(StandaloneCodeEditor editor, string code)
    {
        return new StandaloneEditorConstructionOptions
        {
            Language = "javascript", // Snippets language
            Theme = "vs-dark",
            Value = code,
            ReadOnly = true,
            AutomaticLayout = true,
            Minimap = new EditorMinimapOptions { Enabled = false },
            ScrollBeyondLastLine = false
        };
    }

    private StandaloneEditorConstructionOptions ReplyInputEditorOptions(StandaloneCodeEditor editor)
    {
        return new StandaloneEditorConstructionOptions
        {
            Language = "javascript",
            Theme = "vs-dark",
            Value = "",
            AutomaticLayout = true,
            Minimap = new EditorMinimapOptions { Enabled = false },
            ScrollBeyondLastLine = false
        };
    }

    private async Task SubmitReply()
    {
        isReplying = true;
        try
        {
            if (includeCode && replyInputEditor != null)
            {
                replyModel.code_snippet = await replyInputEditor.GetValue();
            }
            else
            {
                replyModel.code_snippet = null;
            }

            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var userId = authState.User.FindFirst("user_id")?.Value ?? "1"; // Fallback a 1 si no hay

            
            var response = await Http.PostAsJsonAsync($"threads/{Id}/replies?user_id={userId}", replyModel);
            
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("¡Respuesta publicada!", Severity.Success);
                replyModel = new ReplyCreateRequest(); // Limpiar formulario
                includeCode = false;
                await LoadThreadData(); // Recargar el hilo y respuestas sin cambiar de página
            }
            else
            {
                Snackbar.Add("No se pudo guardar la respuesta.", Severity.Error);
            }
        }
        catch (Exception)
        {
            Snackbar.Add("Error de conexión al servidor.", Severity.Error);
        }
        finally
        {
            isReplying = false;
        }
    }

    private async Task MarkAsSolution(int replyId)
    {
        try
        {
            // Omitimos cuerpo en PUT pasando null si la API no requiere body Payload
            var response = await Http.PutAsync($"threads/replies/{replyId}/solution", null);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("¡Solución marcada existosamente!", Severity.Success);
                await LoadThreadData();
            }
            else
            {
                Snackbar.Add("Error al marcar como solución.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error marcando solución: {ex.Message}");
            Snackbar.Add("Error de red al intentar conectar.", Severity.Error);
        }
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/threads");
    }

    // --- DTO CLASSES EN BLOQUE @CODE ---
    public class ThreadDetailResponse
    {
        public int id { get; set; }
        public int author_id { get; set; }
        public string author_username { get; set; } = string.Empty;
        public int author_karma { get; set; }
        public string title { get; set; } = string.Empty;
        public string content { get; set; } = string.Empty;
        public List<ThreadSnippetResponse> snippets { get; set; } = new();
        public DateTime created_at { get; set; }
        
        public List<ReplyResponse> replies { get; set; } = new();
    }

    public class ThreadSnippetResponse
    {
        public int id { get; set; }
        public string filename { get; set; } = string.Empty;
        public string language { get; set; } = string.Empty;
        public string code { get; set; } = string.Empty;
    }

    public class ReplyResponse
    {
        public int id { get; set; }
        public int thread_id { get; set; }
        public int author_id { get; set; }
        public string author_username { get; set; } = string.Empty;
        public int author_karma { get; set; }
        public string content { get; set; } = string.Empty;
        public string? code_snippet { get; set; }
        public bool is_solution { get; set; }
        public DateTime created_at { get; set; }
    }

    public class ReplyCreateRequest
    {
        [Required(ErrorMessage = "La respuesta no puede estar vacía.")]
        public string content { get; set; } = string.Empty;
        public string? code_snippet { get; set; }
    }
}
